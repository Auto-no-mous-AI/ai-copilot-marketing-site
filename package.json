{
  "name": "marketing-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node scripts/validate-frontend-env.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development"
  },
  "prettier": {
    "printWidth": 100,
